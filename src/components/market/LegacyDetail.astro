---
import Icon from "../Icon.astro";
import type {
  ExtensionManifest,
  ModelPackageManifest,
  RegistryEntry,
} from "../../lib/registry-types";

interface Props {
  entry: RegistryEntry;
}

const { entry } = Astro.props;
const m = entry.manifest;

const isModel = entry.category === "model";
const categoryLabel = isModel
  ? "模型包"
  : entry.category === "theme"
    ? "主题"
    : "插件";

const statusMap: Record<string, { text: string; cls: string }> = {
  stable: { text: "稳定版", cls: "bg-emerald-50 text-emerald-700 ring-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-400 dark:ring-emerald-900/50" },
  beta: { text: "Beta", cls: "bg-amber-50 text-amber-700 ring-amber-200 dark:bg-amber-950/40 dark:text-amber-400 dark:ring-amber-900/50" },
  deprecated: { text: "已停用", cls: "bg-red-50 text-red-700 ring-red-200" },
  "coming-soon": { text: "即将上线", cls: "bg-slate-100 text-slate-700 ring-slate-200 dark:bg-slate-800 dark:text-slate-300 dark:ring-slate-700" },
};

// manifest 字段抽取（主题/插件 vs 模型包字段不同）
const description = "description" in m && m.description ? m.description : "";
const author = "author" in m && m.author ? m.author : "BangNiCMS Official";
const tags = ("tags" in m && m.tags) || [];
const highlights = m.marketingMeta?.highlights ?? [];
const targetIndustries = m.marketingMeta?.targetIndustries ?? [];
const changelog = "changelog" in m && m.changelog ? m.changelog : "";

// 主仓 manifest 调用 key（主题/插件用 extensionKey；模型包用 packageKey）
const installKey = isModel
  ? (m as ModelPackageManifest).packageKey
  : (m as ExtensionManifest).extensionKey;

// 安装命令（mock 阶段为占位，真实环境会指向 BangNiCMS 主仓 API）
const installCommand = isModel
  ? `# 在 BangNiCMS 后台「扩展中心 → 模型包」上传安装\n# 或通过命令行：\ncurl -X POST https://your-cms.com/api/2026-04/model-packages/install \\\n  -F "file=@${installKey}-${m.version}.zip" \\\n  -H "Authorization: Bearer YOUR_TOKEN"`
  : `# 在 BangNiCMS 后台「扩展中心」上传安装\n# 或通过命令行：\ncurl -X POST https://your-cms.com/api/2026-04/extensions/install \\\n  -F "file=@${installKey}-${m.version}.zip" \\\n  -H "Authorization: Bearer YOUR_TOKEN"`;

// 简易 markdown → HTML（仅支持本项目 README 用到的语法子集）
function renderMarkdown(md: string): string {
  if (!md) return "";
  // 转义，再按行处理
  const lines = md.split("\n");
  const html: string[] = [];
  let inCode = false;
  let codeLang = "";
  let inTable = false;
  let inList = false;

  for (let raw of lines) {
    const line = raw;

    // 代码块边界
    if (line.startsWith("```")) {
      if (inCode) {
        html.push("</code></pre>");
        inCode = false;
        codeLang = "";
      } else {
        codeLang = line.slice(3).trim();
        html.push(
          `<pre class="bn-code" data-lang="${codeLang}"><code>`,
        );
        inCode = true;
      }
      continue;
    }
    if (inCode) {
      html.push(escapeHtml(raw));
      continue;
    }

    // 标题
    if (line.startsWith("### ")) {
      closeListIfOpen();
      html.push(`<h3>${inline(line.slice(4))}</h3>`);
      continue;
    }
    if (line.startsWith("## ")) {
      closeListIfOpen();
      html.push(`<h2>${inline(line.slice(3))}</h2>`);
      continue;
    }
    if (line.startsWith("# ")) {
      closeListIfOpen();
      html.push(`<h1>${inline(line.slice(2))}</h1>`);
      continue;
    }

    // 表格
    if (line.includes("|") && line.trim().startsWith("|")) {
      const cells = line
        .trim()
        .replace(/^\|/, "")
        .replace(/\|$/, "")
        .split("|")
        .map((c) => c.trim());
      // 分隔行
      if (cells.every((c) => /^:?-+:?$/.test(c))) continue;
      if (!inTable) {
        closeListIfOpen();
        html.push("<table><tbody>");
        inTable = true;
      }
      const isHead = cells.every((c) => /^[A-Za-z\u4e00-\u9fa5\s]+$/.test(c));
      const tag = isHead && html[html.length - 1].endsWith("<tbody>") ? "th" : "td";
      const row = cells.map((c) => `<${tag}>${inline(c)}</${tag}>`).join("");
      html.push(`<tr>${row}</tr>`);
      continue;
    } else if (inTable) {
      html.push("</tbody></table>");
      inTable = false;
    }

    // 列表项
    if (/^[-*]\s+/.test(line)) {
      if (!inList) {
        html.push("<ul>");
        inList = true;
      }
      html.push(`<li>${inline(line.replace(/^[-*]\s+/, ""))}</li>`);
      continue;
    } else if (inList && line.trim() === "") {
      html.push("</ul>");
      inList = false;
      continue;
    } else if (inList) {
      html.push("</ul>");
      inList = false;
    }

    // 空行
    if (line.trim() === "") {
      html.push("");
      continue;
    }

    // 段落
    html.push(`<p>${inline(line)}</p>`);
  }
  if (inCode) html.push("</code></pre>");
  if (inList) html.push("</ul>");
  if (inTable) html.push("</tbody></table>");

  return html.join("\n");

  function closeListIfOpen() {
    if (inList) {
      html.push("</ul>");
      inList = false;
    }
    if (inTable) {
      html.push("</tbody></table>");
      inTable = false;
    }
  }
}

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
}

function inline(s: string): string {
  // 行内代码
  s = s.replace(
    /`([^`]+)`/g,
    '<code class="bn-inline-code">$1</code>',
  );
  // 加粗
  s = s.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
  // 链接
  s = s.replace(
    /\[([^\]]+)\]\(([^)]+)\)/g,
    '<a href="$2" class="bn-link">$1</a>',
  );
  return s;
}

const readmeHtml = renderMarkdown(entry.readme);
const changelogHtml = renderMarkdown(changelog);
---

<main>
    <!-- 面包屑 -->
    <nav class="border-b border-slate-200 dark:border-white/5" aria-label="面包屑">
      <div class="mx-auto flex max-w-6xl items-center gap-2 px-4 py-3 text-sm sm:px-6 lg:px-8">
        <a href="/extensions" class="text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">
          扩展市场
        </a>
        <span class="text-slate-400 dark:text-slate-600">/</span>
        <span class="font-medium text-slate-900 dark:text-white">{m.name}</span>
      </div>
    </nav>

    <!-- Hero -->
    <section class={`bg-gradient-to-br ${entry.coverGradient}`}>
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-6 md:flex-row md:items-start">
          <span class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-white/15 text-white backdrop-blur-sm ring-1 ring-white/20">
            <Icon name={entry.iconKey} class="h-10 w-10" weight={1.75} />
          </span>
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center rounded-md bg-white/15 px-2 py-0.5 text-xs font-medium text-white ring-1 ring-white/20">
                {categoryLabel}
              </span>
              <span
                class={`inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ring-1 ring-inset ${statusMap[entry.status].cls}`}
              >
                {statusMap[entry.status].text}
              </span>
              <span class="text-xs text-white/80">v{m.version}</span>
            </div>
            <h1 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
              {m.name}
            </h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-white/90">
              {description}
            </p>
            <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-white/80">
              <span>by <strong class="text-white">{author}</strong></span>
              <span class="text-white/40">·</span>
              <span>更新于 {entry.updatedAt}</span>
              <span class="text-white/40">·</span>
              <span>{entry.stats.installs.toLocaleString()} 次安装</span>
              <span class="text-white/40">·</span>
              <span class="inline-flex items-center gap-1">
                <Icon name="star" class="h-3 w-3" />
                {entry.stats.stars}
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 主内容（双栏：左 README，右安装命令 + 元信息） -->
    <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_320px]">
        <!-- 左：README + Changelog -->
        <article class="bn-readme">
          {highlights.length > 0 && (
            <div class="mb-8 rounded-lg border border-slate-200 bg-slate-50 p-5 dark:border-white/10 dark:bg-slate-900/50">
              <h3 class="text-sm font-semibold text-slate-900 dark:text-white">主要亮点</h3>
              <ul class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400">
                {highlights.map((h) => (
                  <li class="flex items-start gap-2">
                    <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-slate-500 dark:text-slate-500" weight={2.5} />
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div set:html={readmeHtml} />

          {changelogHtml && (
            <>
              <h2>更新历史</h2>
              <div set:html={changelogHtml} />
            </>
          )}
        </article>

        <!-- 右：安装命令 + 元信息 -->
        <aside class="space-y-5">
          <!-- 安装命令 -->
          <div class="rounded-lg border border-slate-200 bg-white dark:border-white/10 dark:bg-slate-900">
            <div class="border-b border-slate-200 px-4 py-3 dark:border-white/10">
              <h3 class="text-sm font-semibold text-slate-900 dark:text-white">安装</h3>
            </div>
            <div class="p-4">
              <div class="relative">
                <pre class="overflow-x-auto rounded-md bg-slate-900 p-3 text-xs leading-5 text-slate-200 dark:bg-slate-950"><code id="install-cmd">{installCommand}</code></pre>
                <button
                  type="button"
                  id="install-copy"
                  class="absolute right-2 top-2 inline-flex items-center gap-1 rounded-md bg-slate-800 px-2 py-1 text-[11px] font-medium text-slate-300 transition-colors hover:bg-slate-700"
                  aria-label="复制安装命令"
                >
                  <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                  </svg>
                  <span id="install-copy-text">复制</span>
                </button>
              </div>
              <a
                href={entry.downloadUrl}
                class="mt-3 inline-flex w-full items-center justify-center gap-1.5 rounded-md bg-slate-900 px-3 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
              >
                下载 .zip 包
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
              </a>
            </div>
          </div>

          <!-- 元信息 -->
          <div class="rounded-lg border border-slate-200 bg-white p-4 dark:border-white/10 dark:bg-slate-900">
            <h3 class="text-sm font-semibold text-slate-900 dark:text-white">元信息</h3>
            <dl class="mt-3 space-y-2.5 text-sm">
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500 dark:text-slate-400">标识符</dt>
                <dd class="font-mono text-xs text-slate-900 dark:text-white">{installKey}</dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500 dark:text-slate-400">当前版本</dt>
                <dd class="text-slate-900 dark:text-white">v{m.version}</dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500 dark:text-slate-400">首次发布</dt>
                <dd class="text-slate-900 dark:text-white">{entry.releasedAt}</dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500 dark:text-slate-400">最近更新</dt>
                <dd class="text-slate-900 dark:text-white">{entry.updatedAt}</dd>
              </div>
              {targetIndustries.length > 0 && (
                <div class="flex justify-between gap-3">
                  <dt class="shrink-0 text-slate-500 dark:text-slate-400">适用行业</dt>
                  <dd class="text-right text-slate-900 dark:text-white">
                    {targetIndustries.join(" / ")}
                  </dd>
                </div>
              )}
              {entry.documentationUrl && (
                <div class="flex justify-between gap-3">
                  <dt class="text-slate-500 dark:text-slate-400">文档</dt>
                  <dd>
                    <a href={entry.documentationUrl} class="text-brand-600 hover:underline dark:text-brand-400">
                      查看 →
                    </a>
                  </dd>
                </div>
              )}
              {entry.repositoryUrl && (
                <div class="flex justify-between gap-3">
                  <dt class="text-slate-500 dark:text-slate-400">仓库</dt>
                  <dd>
                    <a href={entry.repositoryUrl} target="_blank" rel="noopener" class="text-brand-600 hover:underline dark:text-brand-400">
                      GitHub →
                    </a>
                  </dd>
                </div>
              )}
            </dl>
          </div>

          <!-- 标签 -->
          {tags.length > 0 && (
            <div class="rounded-lg border border-slate-200 bg-white p-4 dark:border-white/10 dark:bg-slate-900">
              <h3 class="text-sm font-semibold text-slate-900 dark:text-white">标签</h3>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {tags.map((t) => (
                  <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-1 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-400">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- API 链接（开发者向） -->
          <div class="rounded-lg border border-dashed border-slate-200 bg-slate-50 p-4 text-xs text-slate-500 dark:border-white/10 dark:bg-slate-900/50 dark:text-slate-500">
            <p class="font-medium text-slate-700 dark:text-slate-300">开发者：</p>
            <p class="mt-1">
              获取此扩展元数据 JSON：
            </p>
            <a
              href={`/api/v1/registry/extensions/${entry.slug}.json`}
              class="mt-1.5 block break-all font-mono text-brand-600 hover:underline dark:text-brand-400"
            >
              /api/v1/registry/extensions/{entry.slug}.json
            </a>
          </div>
        </aside>
      </div>
    </section>
  </main>


<script>
  const btn = document.getElementById("install-copy");
  const cmdEl = document.getElementById("install-cmd");
  const txt = document.getElementById("install-copy-text");
  btn?.addEventListener("click", async () => {
    if (!cmdEl) return;
    try {
      await navigator.clipboard.writeText(cmdEl.textContent ?? "");
      if (txt) txt.textContent = "已复制";
      setTimeout(() => {
        if (txt) txt.textContent = "复制";
      }, 1500);
    } catch (err) {
      console.error("Copy failed", err);
    }
  });
</script>

<style is:global>
  /* README 样式：参考文档站排版规范 */
  .bn-readme {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: rgb(51 65 85); /* slate-700 */
  }
  :global(.dark) .bn-readme {
    color: rgb(203 213 225); /* slate-300 */
  }

  .bn-readme h1,
  .bn-readme h2,
  .bn-readme h3 {
    color: rgb(15 23 42); /* slate-900 */
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  :global(.dark) .bn-readme h1,
  :global(.dark) .bn-readme h2,
  :global(.dark) .bn-readme h3 {
    color: white;
  }

  .bn-readme h1 {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .bn-readme h2 {
    font-size: 1.25rem;
    margin-top: 2.5rem;
    margin-bottom: 0.875rem;
  }
  .bn-readme h3 {
    font-size: 1.0625rem;
    margin-top: 1.75rem;
    margin-bottom: 0.625rem;
  }

  .bn-readme h1:first-child,
  .bn-readme h2:first-child {
    margin-top: 0;
  }

  .bn-readme p {
    margin: 0.875rem 0;
  }

  .bn-readme ul {
    margin: 0.875rem 0;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .bn-readme li {
    margin: 0.375rem 0;
  }

  .bn-readme a.bn-link {
    color: rgb(2 132 199); /* sky-600 */
    text-decoration: none;
    border-bottom: 1px solid rgb(2 132 199 / 0.35);
    transition: border-color 200ms ease;
  }
  .bn-readme a.bn-link:hover {
    border-bottom-color: rgb(2 132 199);
  }
  :global(.dark) .bn-readme a.bn-link {
    color: rgb(56 189 248); /* sky-400 */
    border-bottom-color: rgb(56 189 248 / 0.35);
  }

  .bn-readme code.bn-inline-code {
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875em;
    font-weight: 500;
    background: rgb(241 245 249); /* slate-100 */
    color: rgb(15 23 42);
    font-family: "JetBrains Mono", "SF Mono", monospace;
  }
  :global(.dark) .bn-readme code.bn-inline-code {
    background: rgb(30 41 59); /* slate-800 */
    color: rgb(226 232 240);
  }

  .bn-readme pre.bn-code {
    margin: 1rem 0;
    overflow-x: auto;
    border-radius: 6px;
    background: rgb(15 23 42); /* slate-900 */
    color: rgb(226 232 240); /* slate-200 */
    padding: 0.875rem 1rem;
    font-size: 0.8125rem;
    line-height: 1.6;
  }
  .bn-readme pre.bn-code code {
    font-family: "JetBrains Mono", "SF Mono", monospace;
    background: transparent;
    color: inherit;
  }

  .bn-readme table {
    margin: 1rem 0;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    border: 1px solid rgb(226 232 240); /* slate-200 */
    border-radius: 6px;
    overflow: hidden;
  }
  :global(.dark) .bn-readme table {
    border-color: rgba(255, 255, 255, 0.1);
  }
  .bn-readme th,
  .bn-readme td {
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid rgb(226 232 240);
  }
  :global(.dark) .bn-readme th,
  :global(.dark) .bn-readme td {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }
  .bn-readme th {
    background: rgb(248 250 252); /* slate-50 */
    font-weight: 600;
    font-size: 0.8125rem;
    color: rgb(15 23 42);
  }
  :global(.dark) .bn-readme th {
    background: rgb(15 23 42 / 0.5);
    color: white;
  }
  .bn-readme tr:last-child td {
    border-bottom: none;
  }
</style>
