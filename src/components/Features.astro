    desc: "翻译、SEO 建议、内容改写、自动摘要，全部嵌在编辑器里，不需要离开后台另开标签页。",
    iconPath: "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 16a6 6 0 1 1 6-6 6 6 0 0 1-6 6zm0-10a4 4 0 1 0 4 4 4 4 0 0 0-4-4z",
    accent: "from-rose-500 to-orange-500",
