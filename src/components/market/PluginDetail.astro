---
/**
 * 插件详情页模板：以"功能 + 价值 + 怎么用"为核心
 *
 * 信息架构：
 *   1. Hero（标题 + tagline + 价值数字徽章 + CTA）
 *   2. 解决什么问题（problemStatement）
 *   3. 核心功能（features 6 张大卡）
 *   4. 带来的价值（valueProps 数字带）
 *   5. 设置流程（setupSteps 3 步）
 *   6. FAQ（faqs 折叠）
 *   7. CTA 转化区
 *   8. 开发者信息（折叠）
 */
import Icon from "../Icon.astro";
import type { RegistryEntry, ExtensionManifest } from "../../lib/registry-types";

interface Props {
  entry: RegistryEntry;
}

const { entry } = Astro.props;
const m = entry.manifest as ExtensionManifest;
const p = entry.pluginInfo!;

const statusMap: Record<string, { text: string; cls: string }> = {
  stable: { text: "稳定版", cls: "bg-emerald-50 text-emerald-700 ring-emerald-200 dark:bg-emerald-950/40 dark:text-emerald-400 dark:ring-emerald-900/50" },
  beta: { text: "Beta", cls: "bg-amber-50 text-amber-700 ring-amber-200 dark:bg-amber-950/40 dark:text-amber-400 dark:ring-amber-900/50" },
  deprecated: { text: "已停用", cls: "bg-red-50 text-red-700 ring-red-200" },
  "coming-soon": { text: "即将上线", cls: "bg-slate-100 text-slate-700 ring-slate-200 dark:bg-slate-800 dark:text-slate-300 dark:ring-slate-700" },
};

const installCommand = `# 在 BangNiCMS 后台「扩展中心」上传安装
# 或通过命令行：
curl -X POST https://your-cms.com/api/2026-04/extensions/install \\
  -F "file=@${m.extensionKey}-${m.version}.zip" \\
  -H "Authorization: Bearer YOUR_TOKEN"`;
---

<main>
  <!-- ─────────────────── 1. Hero ─────────────────── -->
  <section class="relative overflow-hidden border-b border-slate-200 dark:border-white/5">
    <div class={`absolute inset-0 bg-gradient-to-br ${entry.coverGradient} opacity-95`}></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:48px_48px]"></div>

    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="mb-8 flex items-center gap-2 text-sm text-white/80">
        <a href="/extensions" class="transition-colors hover:text-white">扩展市场</a>
        <span>/</span>
        <span class="text-white">{m.name}</span>
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_360px] lg:items-center">
        <div>
          <div class="mb-5 flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-md bg-white/15 px-2.5 py-1 text-xs font-medium text-white ring-1 ring-white/20 backdrop-blur-sm">
              <Icon name="puzzle" class="h-3.5 w-3.5" />
              插件
            </span>
            <span class={`inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset ${statusMap[entry.status].cls}`}>
              {statusMap[entry.status].text}
            </span>
            <span class="text-sm text-white/70">v{m.version}</span>
          </div>

          <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
            {m.name}
          </h1>
          <p class="mt-5 max-w-xl text-lg leading-8 text-white/90">
            {p.tagline}
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a
              href={entry.downloadUrl}
              class="inline-flex items-center gap-1.5 rounded-md bg-white px-5 py-2.5 text-sm font-medium text-slate-900 shadow-md transition-all hover:bg-slate-100"
            >
              <Icon name="download" class="h-4 w-4" weight={2.5} />
              免费下载
            </a>
            {entry.documentationUrl && (
              <a
                href={entry.documentationUrl}
                class="inline-flex items-center gap-1.5 rounded-md bg-white/10 px-5 py-2.5 text-sm font-medium text-white ring-1 ring-white/20 backdrop-blur-sm transition-all hover:bg-white/20"
              >
                <Icon name="external-link" class="h-4 w-4" weight={2.5} />
                阅读文档
              </a>
            )}
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-white/70">
            <span>by <strong class="font-semibold text-white">{m.author}</strong></span>
            <span class="inline-flex items-center gap-1">
              <Icon name="download" class="h-3 w-3" />
              {entry.stats.installs.toLocaleString()} 次安装
            </span>
            <span class="inline-flex items-center gap-1">
              <Icon name="star" class="h-3 w-3" />
              {entry.stats.stars}
            </span>
            <span>更新于 {entry.updatedAt}</span>
          </div>
        </div>

        <!-- 右侧：价值数字方阵 -->
        <div class="grid grid-cols-2 gap-3">
          {p.valueProps.slice(0, 4).map((vp) => (
            <div class="rounded-xl bg-white/10 p-5 ring-1 ring-white/15 backdrop-blur-sm">
              <div class="text-3xl font-bold tracking-tight text-white">
                {vp.metric}
              </div>
              <div class="mt-1 text-xs text-white/80">
                {vp.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────── 2. 解决什么问题 ─────────────────── -->
  <section class="border-b border-slate-200 bg-white dark:border-white/5 dark:bg-slate-950">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-400">
          <Icon name="target" class="h-3.5 w-3.5" />
          解决什么问题
        </span>
        <h2 class="mt-4 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
          为什么需要这个插件？
        </h2>
      </div>
      <div class="mt-8 space-y-5">
        {p.problemStatement.map((para) => (
          <p class="text-base leading-8 text-slate-600 dark:text-slate-300">{para}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────── 3. 核心功能（6 张卡） ─────────────── -->
  <section class="border-b border-slate-200 bg-slate-50 dark:border-white/5 dark:bg-slate-900/30">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
          核心功能
        </h2>
        <p class="mx-auto mt-3 max-w-2xl text-base text-slate-600 dark:text-slate-400">
          安装后立即可用的 {p.features.length} 个核心能力。
        </p>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-2">
        {p.features.map((f) => (
          <div class="group rounded-xl border border-slate-200 bg-white p-6 transition-all hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg dark:border-white/10 dark:bg-slate-900 dark:hover:border-white/20">
            <div class="flex items-start gap-4">
              <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                <Icon name={f.icon} class="h-5 w-5" />
              </span>
              <div class="flex-1">
                <h3 class="text-base font-semibold text-slate-900 dark:text-white">
                  {f.title}
                </h3>
                <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">
                  {f.summary}
                </p>
                <ul class="mt-4 space-y-1.5 text-xs leading-6 text-slate-500 dark:text-slate-500">
                  {f.details.map((d) => (
                    <li class="flex items-start gap-2">
                      <Icon name="check" class="mt-1 h-3 w-3 shrink-0 text-slate-400" weight={2.5} />
                      <span>{d}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────── 4. 价值数字带 ─────────────── -->
  <section class="border-b border-slate-200 bg-white dark:border-white/5 dark:bg-slate-950">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
        带来的价值
      </h2>
      <p class="mt-2 max-w-2xl text-sm text-slate-600 dark:text-slate-400">
        基于已安装站点的实际数据。
      </p>

      <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-4">
        {p.valueProps.map((vp) => (
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-6 dark:border-white/10 dark:bg-slate-900/30">
            <div class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">
              {vp.metric}
            </div>
            <div class="mt-2 text-sm text-slate-600 dark:text-slate-400">
              {vp.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────── 5. 设置流程 ─────────────── -->
  <section class="border-b border-slate-200 bg-slate-50 dark:border-white/5 dark:bg-slate-900/30">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
        如何启用
      </h2>
      <p class="mt-2 max-w-2xl text-sm text-slate-600 dark:text-slate-400">
        三步上手，全程不需要写代码。
      </p>

      <div class="relative mt-10">
        <!-- 连接线 -->
        <div class="absolute left-4 top-4 hidden h-0.5 w-[calc(100%-2rem)] bg-slate-200 md:block dark:bg-white/10"></div>

        <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
          {p.setupSteps.map((step, i) => (
            <div class="relative rounded-xl border border-slate-200 bg-white p-6 dark:border-white/10 dark:bg-slate-900">
              <span class="relative z-10 inline-flex h-8 w-8 items-center justify-center rounded-full bg-slate-900 text-sm font-bold text-white dark:bg-white dark:text-slate-900">
                {i + 1}
              </span>
              <h3 class="mt-4 text-base font-semibold text-slate-900 dark:text-white">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">
                {step.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────── 6. FAQ ─────────────── -->
  {p.faqs.length > 0 && (
    <section class="border-b border-slate-200 bg-white dark:border-white/5 dark:bg-slate-950">
      <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
          常见问题
        </h2>
        <div class="mt-8 space-y-3">
          {p.faqs.map((f) => (
            <details class="group rounded-xl border border-slate-200 bg-white p-5 open:border-slate-300 dark:border-white/10 dark:bg-slate-900/50 dark:open:border-white/20">
              <summary class="flex cursor-pointer items-start justify-between gap-4 text-sm font-medium text-slate-900 dark:text-white">
                <span>{f.q}</span>
                <Icon name="plus" class="h-4 w-4 shrink-0 text-slate-400 transition-transform group-open:rotate-45" weight={2} />
              </summary>
              <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-400">
                {f.a}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ─────────────── 7. CTA 转化区 ─────────────── -->
  <section class="bg-slate-900 dark:bg-slate-950">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_400px] lg:items-center">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            准备好提升你的站点效果了吗？
          </h2>
          <p class="mt-4 max-w-xl text-base text-slate-300">
            立即下载 <strong class="font-semibold text-white">{m.name}</strong>，安装后所有功能立即生效。
          </p>
          <div class="mt-6 flex flex-wrap items-center gap-3">
            <a
              href={entry.downloadUrl}
              class="inline-flex items-center gap-1.5 rounded-md bg-white px-5 py-2.5 text-sm font-medium text-slate-900 shadow-md transition-all hover:bg-slate-100"
            >
              <Icon name="download" class="h-4 w-4" weight={2.5} />
              下载 .zip
            </a>
            {entry.documentationUrl && (
              <a
                href={entry.documentationUrl}
                class="inline-flex items-center gap-1.5 rounded-md bg-white/10 px-5 py-2.5 text-sm font-medium text-white ring-1 ring-white/20 transition-all hover:bg-white/20"
              >
                阅读文档 →
              </a>
            )}
          </div>
        </div>

        <div class="rounded-xl border border-white/10 bg-slate-800/50 p-5">
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-wide text-slate-400">命令行安装</span>
            <button
              type="button"
              id="plugin-install-copy"
              class="inline-flex items-center gap-1 rounded-md bg-white/10 px-2 py-1 text-[11px] font-medium text-slate-200 transition-colors hover:bg-white/20"
            >
              <Icon name="copy" class="h-3 w-3" />
              <span id="plugin-install-copy-text">复制</span>
            </button>
          </div>
          <pre class="mt-3 overflow-x-auto rounded-md bg-slate-950 p-3 text-xs leading-5 text-slate-200"><code id="plugin-install-cmd">{installCommand}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────── 8. 开发者信息（折叠） ─────────────── -->
  <section class="border-t border-slate-200 bg-white dark:border-white/5 dark:bg-slate-950">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
      <details class="group">
        <summary class="flex cursor-pointer items-center justify-between gap-2 text-sm text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-500 dark:hover:text-slate-300">
          <span class="inline-flex items-center gap-2">
            <Icon name="layers" class="h-4 w-4" />
            开发者信息
          </span>
          <Icon name="plus" class="h-4 w-4 transition-transform group-open:rotate-45" />
        </summary>
        <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4">
          <div>
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">标识符</div>
            <div class="mt-1 font-mono text-xs text-slate-900 dark:text-white">{m.extensionKey}</div>
          </div>
          <div>
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">首次发布</div>
            <div class="mt-1 text-sm text-slate-900 dark:text-white">{entry.releasedAt}</div>
          </div>
          <div>
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">仓库</div>
            <div class="mt-1">
              {entry.repositoryUrl ? (
                <a href={entry.repositoryUrl} target="_blank" rel="noopener" class="text-sm text-brand-600 hover:underline dark:text-brand-400">GitHub →</a>
              ) : <span class="text-sm text-slate-500">—</span>}
            </div>
          </div>
          <div>
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">JSON 元数据</div>
            <a href={`/api/v1/registry/extensions/${entry.slug}.json`} class="mt-1 block break-all font-mono text-xs text-brand-600 hover:underline dark:text-brand-400">
              /api/v1/registry/extensions/{entry.slug}.json
            </a>
          </div>
        </div>
      </details>
    </div>
  </section>
</main>

<script>
  const btn = document.getElementById("plugin-install-copy");
  const cmd = document.getElementById("plugin-install-cmd");
  const txt = document.getElementById("plugin-install-copy-text");
  btn?.addEventListener("click", async () => {
    if (!cmd) return;
    try {
      await navigator.clipboard.writeText(cmd.textContent ?? "");
      if (txt) txt.textContent = "已复制";
      setTimeout(() => { if (txt) txt.textContent = "复制"; }, 1500);
    } catch (err) { console.error("Copy failed", err); }
  });
</script>
