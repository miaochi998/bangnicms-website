---

<section
  id="features"
  class="relative bg-white py-24 sm:py-32 dark:bg-slate-950"
  aria-label="核心特性"
>
  <!-- 顶部背景装饰 -->
  <div
    class="pointer-events-none absolute inset-0 bg-grid [mask-image:radial-gradient(ellipse_50%_60%_at_50%_50%,black,transparent)]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- 标题区 -->
    <div class="reveal mx-auto max-w-3xl text-center">
      <p
        class="text-sm font-semibold tracking-wider text-brand-500 uppercase"
      >
        Why BangNiCMS
      </p>
      <h2
        class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl dark:text-white"
      >
        所有现代 CMS 该有的，
        <span class="gradient-text">我们都给你做好了</span>
      </h2>
      <p class="mt-5 text-lg text-slate-600 dark:text-slate-400">
        八大核心能力，无论你是个人博主、企业官网、还是外贸卖家，都能即装即用。
      </p>
    </div>

    <!-- 特性卡片网格 -->
    <ul
      class="mt-16 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"
      role="list"
    >
      {
        features.map((feat, i) => (
          <li
            class="reveal feature-card group relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-6 transition-all duration-300 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/5 dark:border-white/10 dark:bg-slate-900/50 dark:hover:border-brand-500/40 dark:hover:bg-slate-900"
            style={`transition-delay: ${(i % 4) * 60}ms`}
          >
            {/* 角落渐变光晕（hover 时显现） */}
            <div
              class={`pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full bg-gradient-to-br ${feat.accent} opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-30`}
              aria-hidden="true"
            />

            {/* 图标 */}
            <div
              class={`relative inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br ${feat.accent} text-white shadow-lg shadow-slate-900/10`}
            >
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={feat.iconPath} />
              </svg>
            </div>

            {/* 文字 */}
            <h3 class="relative mt-5 text-base font-semibold text-slate-900 dark:text-white">
              {feat.title}
            </h3>
            <p class="relative mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              {feat.desc}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  // 鼠标 3D 倾斜微交互（仅指针设备启用）
  const isFinePointer = window.matchMedia("(pointer: fine)").matches;
  if (isFinePointer && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const cards = document.querySelectorAll<HTMLElement>(".feature-card");
    cards.forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const cx = rect.width / 2;
        const cy = rect.height / 2;
        const rx = ((y - cy) / cy) * -3; // 最大 ±3deg
        const ry = ((x - cx) / cx) * 3;
        card.style.transform = `perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(0)`;
      });
      card.addEventListener("mouseleave", () => {
        card.style.transform = "";
      });
    });
  }
</script>
