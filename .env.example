# ============================================================
# BangNiCMS 官方站 — 环境变量模板
# ------------------------------------------------------------
# 使用方式：
#   cp .env.example .env
#   编辑 .env 填入下方变量
#
# 仅在服务器上需要 .env；本地开发不需要（pnpm dev 直接跑即可）
# ============================================================

# ── 主站域名（已备案）──
DOMAIN=cms.bonnei.com

# ── Let's Encrypt 续期通知邮箱 ──
ADMIN_EMAIL=admin@bonnei.com
