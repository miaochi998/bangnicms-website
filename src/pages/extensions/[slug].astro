---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ThemeDetail from "../../components/market/ThemeDetail.astro";
import LegacyDetail from "../../components/market/LegacyDetail.astro";
import { registryEntries } from "../../registry/entries";

export async function getStaticPaths() {
  return registryEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const m = entry.manifest;

const description = "description" in m && m.description ? m.description : "";

const useNewTemplate = entry.category === "theme" && entry.themeInfo;
---

<BaseLayout
  title={`${m.name} - 扩展市场 - BangNiCMS`}
  description={description}
>
  <Header slot="header" />

  {useNewTemplate ? <ThemeDetail entry={entry} /> : <LegacyDetail entry={entry} />}

  <Footer slot="footer" />
</BaseLayout>
