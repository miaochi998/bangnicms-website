---
import Icon from "./Icon.astro";
const currentYear = new Date().getFullYear();

const groups = [
  {
    title: "产品",
    links: [
      { label: "首页", href: "/" },
      { label: "产品特性", href: "/#features" },
      { label: "快速开始", href: "/#quick-start" },
      { label: "扩展市场", href: "/extensions" },
    ],
  },
  {
    title: "文档",
    links: [
      { label: "安装部署", href: "/docs/getting-started/installation" },
      { label: "文档首页", href: "/docs" },
    ],
  },
  {
    title: "生态",
    links: [
      { label: "GitHub", href: "https://github.com/miaochi998/BangNiCMS" },
      { label: "提交反馈", href: "https://github.com/miaochi998/BangNiCMS/issues" },
    ],
  },
];
---

<footer class="border-t border-slate-200 bg-slate-50 dark:border-white/10 dark:bg-slate-900">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <!-- Brand 列 -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5">
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-violet-500 to-brand-500 text-white"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h6a4 4 0 0 1 0 8H4z" />
              <path d="M4 12h7a4 4 0 0 1 0 8H4z" />
            </svg>
          </span>
          <span class="text-base font-semibold text-slate-900 dark:text-white">
            BangNiCMS
          </span>
        </a>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
          开箱即用的内容管理系统，<br />专为中文站长打造。
        </p>
      </div>

      <!-- 链接列 -->
      {
        groups.map((group) => (
          <div>
            <h3 class="text-sm font-semibold text-slate-900 dark:text-white">
              {group.title}
            </h3>
            <ul class="mt-4 space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-600 transition-colors hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- 底部分隔条 -->
    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-slate-200 pt-8 text-xs text-slate-500 sm:flex-row dark:border-white/10 dark:text-slate-500"
    >
      <p>
        © {currentYear} BangNiCMS · MIT License
      </p>
      <p class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
        <a
          href="https://beian.miit.gov.cn/"
          target="_blank"
          rel="noopener noreferrer"
          class="link-underline transition-colors hover:text-slate-700 dark:hover:text-slate-300"
        >
          ICP 备案号待补充
        </a>
        <span aria-hidden="true">·</span>
        <span class="inline-flex items-center gap-1">
          Made with
          <Icon name="heart" class="h-3 w-3" />
          in China
        </span>
      </p>
    </div>
  </div>
</footer>
