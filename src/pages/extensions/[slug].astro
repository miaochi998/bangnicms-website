---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ThemeDetail from "../../components/market/ThemeDetail.astro";
import PluginDetail from "../../components/market/PluginDetail.astro";
import ModelDetail from "../../components/market/ModelDetail.astro";
import LegacyDetail from "../../components/market/LegacyDetail.astro";
import { registryEntries } from "../../registry/entries";

export async function getStaticPaths() {
  return registryEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const m = entry.manifest;

const description = "description" in m && m.description ? m.description : "";

// 根据 category + 富信息可用性选择对应模板，否则 fallback 到 LegacyDetail
const useTheme = entry.category === "theme" && entry.themeInfo;
const usePlugin = entry.category === "plugin" && entry.pluginInfo;
const useModel = entry.category === "model" && entry.modelInfo;
---

<BaseLayout
  title={`${m.name} - 扩展市场 - BangNiCMS`}
  description={description}
>
  <Header slot="header" />

  {useTheme ? (
    <ThemeDetail entry={entry} />
  ) : usePlugin ? (
    <PluginDetail entry={entry} />
  ) : useModel ? (
    <ModelDetail entry={entry} />
  ) : (
    <LegacyDetail entry={entry} />
  )}

  <Footer slot="footer" />
</BaseLayout>
