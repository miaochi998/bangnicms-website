---
const navItems = [
  { label: "产品特性", href: "#features" },
  { label: "快速开始", href: "#quick-start" },
  { label: "文档", href: "/docs" },
  { label: "扩展市场", href: "/market" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-40 transition-all duration-300"
  data-scrolled="false"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
  >
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5" aria-label="返回首页">
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-violet-500 to-brand-500 text-white shadow-sm shadow-brand-500/30 transition-transform group-hover:scale-105"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h6a4 4 0 0 1 0 8H4z" />
          <path d="M4 12h7a4 4 0 0 1 0 8H4z" />
        </svg>
      </span>
      <span class="text-base font-semibold tracking-tight text-slate-900 dark:text-white">
        BangNiCMS
      </span>
    </a>

    <!-- 桌面导航 -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="主导航">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="rounded-md px-3 py-1.5 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-white/5 dark:hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- 右侧操作 -->
    <div class="flex items-center gap-2">
      <!-- 暗色模式切换 -->
      <button
        id="theme-toggle"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-white/5 dark:hover:text-white"
        aria-label="切换深色模式"
      >
        <svg class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
      </button>

      <!-- GitHub -->
      <a
        href="https://github.com/miaochi998/BangNiCMS"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden h-9 w-9 items-center justify-center rounded-md text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900 sm:inline-flex dark:text-slate-300 dark:hover:bg-white/5 dark:hover:text-white"
        aria-label="GitHub 仓库"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.11-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.27-5.23-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.18-1.48 3.14-1.17 3.14-1.17.62 1.59.23 2.76.11 3.05.74.8 1.18 1.82 1.18 3.07 0 4.39-2.69 5.36-5.25 5.65.41.36.78 1.05.78 2.12 0 1.53-.01 2.77-.01 3.15 0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
      </a>

      <!-- CTA -->
      <a
        href="#quick-start"
        class="inline-flex items-center gap-1.5 rounded-md bg-slate-900 px-3.5 py-2 text-sm font-medium text-white shadow-sm transition-all hover:bg-slate-800 hover:shadow-md dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
      >
        立即试用
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>

  <!-- 滚动后底部细线 -->
  <div
    class="header-divider absolute inset-x-0 bottom-0 h-px scale-x-0 bg-slate-200 transition-transform duration-300 dark:bg-white/10"
  ></div>
</header>

<!-- Header 占位高度（fixed 定位需要） -->
<div class="h-16" aria-hidden="true"></div>

<script>
  // 滚动时给 header 加背景模糊 + 显示分隔线
  const header = document.getElementById("site-header");
  const divider = header?.querySelector<HTMLElement>(".header-divider");

  const updateHeader = () => {
    if (!header || !divider) return;
    const scrolled = window.scrollY > 8;
    header.dataset.scrolled = String(scrolled);
    if (scrolled) {
      header.classList.add(
        "bg-white/80",
        "backdrop-blur-md",
        "dark:bg-slate-950/80",
      );
      divider.classList.remove("scale-x-0");
    } else {
      header.classList.remove(
        "bg-white/80",
        "backdrop-blur-md",
        "dark:bg-slate-950/80",
      );
      divider.classList.add("scale-x-0");
    }
  };
  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });

  // 主题切换
  const themeToggle = document.getElementById("theme-toggle");
  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
