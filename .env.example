# ============================================================
# BangNiCMS 官方宣传站 — 环境变量模板
# ------------------------------------------------------------
# 使用方式：
#   cp .env.example .env
#   编辑 .env 填入下方密钥
#
# 生成密钥（任选一个）：
#   openssl rand -hex 24
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# ============================================================

# ── BangNiCMS 镜像版本（生产环境固定到具体版本，开发期可暂用 latest）──
BANGNICMS_VERSION=0.2.4

# ── 运行模式（development | production）──
NODE_ENV=production

# ── 必填密钥（3 个，每个都要单独生成）──
BANGNICMS_POSTGRES_PASSWORD=请用_openssl_rand_hex_24_生成填入
BANGNICMS_JWT_SECRET=请用_openssl_rand_hex_24_生成填入
BANGNICMS_REVALIDATE_SECRET=请用_openssl_rand_hex_24_生成填入

# ── 站点域名（本地开发可保持默认）──
BANGNICMS_SITE_HOST=localhost
BANGNICMS_PUBLIC_ORIGIN=http://localhost:6530
BANGNICMS_PUBLIC_WEB_ORIGIN=http://localhost:6532
BANGNICMS_PUBLIC_ADMIN_ORIGIN=http://localhost:6534

# ── 端口（本地避免冲突时可改）──
BANGNICMS_SERVER_PORT=6530
BANGNICMS_WEB_PORT=6532
BANGNICMS_ADMIN_PORT=6534

# ── 生产部署示例（备案后切到正式域名时打开下方）──
# NODE_ENV=production
# BANGNICMS_SITE_HOST=cms.bangni.com
# BANGNICMS_PUBLIC_ORIGIN=https://cms.bangni.com
# BANGNICMS_PUBLIC_WEB_ORIGIN=https://cms.bangni.com
# BANGNICMS_PUBLIC_ADMIN_ORIGIN=https://admin.cms.bangni.com
